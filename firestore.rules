rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net (Zero-Trust, Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Helper Primitives & Security Hardening
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isEmailVerified() && request.auth.token.email == "mchethiyabandara@gmail.com";
    }

    function hasPlayerName(name) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.playerName == name;
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_ \\-]+$'); 
    }

    function isValidChatMessage(data) {
      return (
        data.keys().hasAll(['senderId', 'senderName', 'text', 'channel']) &&
        data.senderId is string &&
        data.senderName is string &&
        data.text is string && data.text.size() > 0 && data.text.size() <= 1024 &&
        data.channel is string
      );
    }

    function isValidFriendship(data) {
      return (
        data.keys().hasAll(['userUids', 'status', 'requestedBy', 'createdAt']) &&
        data.keys().size() == 4 &&
        data.userUids is list && data.userUids.size() == 2 &&
        data.status in ['pending', 'accepted'] &&
        data.requestedBy is string
      );
    }
    
    function isValidLeaderboardEntry(data) {
      return (
        data.keys().hasAll(['playerName', 'level', 'gold', 'job', 'rank', 'updatedAt']) &&
        data.keys().size() >= 6 && data.keys().size() <= 10 &&
        data.playerName is string && data.playerName.size() > 0 && data.playerName.size() <= 64 &&
        data.level is number && data.level >= 0 && data.level <= 9999 &&
        data.gold is number && data.gold >= 0 &&
        data.job is string && data.job.size() <= 64 &&
        data.rank is string && data.rank.size() <= 64 &&
        (!data.keys().hasAll(['customAvatar']) || data.customAvatar is string) &&
        (!data.keys().hasAll(['exp']) || data.exp is number)
      );
    }

    function isValidAnnouncement(data) {
      return (
        data.keys().hasAll(['id', 'title', 'message', 'severity', 'createdAt']) &&
        data.keys().size() == 5 &&
        data.id is string && data.id.size() <= 128 &&
        data.title is string && data.title.size() > 0 && data.title.size() <= 128 &&
        data.message is string && data.message.size() > 0 && data.message.size() <= 2048 &&
        data.severity is string && (data.severity == 'info' || data.severity == 'warning' || data.severity == 'emergency')
      );
    }

    function isValidAdminQuest(data) {
      return (
        data.keys().hasAll(['id', 'name', 'description', 'target', 'rewardExp', 'rewardGold', 'type', 'createdAt']) &&
        data.keys().size() == 8 &&
        data.id is string && data.id.size() <= 128 &&
        data.name is string && data.name.size() > 0 && data.name.size() <= 128 &&
        data.description is string && data.description.size() > 0 && data.description.size() <= 1024 &&
        data.target is number && data.target >= 0 &&
        data.rewardExp is number && data.rewardExp >= 0 &&
        data.rewardGold is number && data.rewardGold >= 0 &&
        data.type is string && (data.type == 'Daily' || data.type == 'Emergency' || data.type == 'Story')
      );
    }

    function isValidAdminGate(data) {
      return (
        data.keys().hasAll(['id', 'name', 'minLevel', 'difficulty', 'expReward', 'goldReward', 'lootItemName', 'isActive', 'createdAt']) &&
        data.keys().size() == 9 &&
        data.id is string && data.id.size() <= 128 &&
        data.name is string && data.name.size() > 0 && data.name.size() <= 128 &&
        data.minLevel is number && data.minLevel >= 0 &&
        data.difficulty is string && data.difficulty.size() <= 32 &&
        data.expReward is number && data.expReward >= 0 &&
        data.goldReward is number && data.goldReward >= 0 &&
        data.lootItemName is string && data.lootItemName.size() <= 128 &&
        data.isActive is bool
      );
    }

    function isValidForumPost(data) {
      return (
        data.keys().hasAll(['sender', 'hunterClass', 'guild', 'text', 'timestamp']) &&
        data.keys().size() == 5 &&
        data.sender is string && data.sender.size() <= 64 &&
        data.hunterClass is string && data.hunterClass.size() <= 64 &&
        data.guild is string && data.guild.size() <= 64 &&
        data.text is string && data.text.size() <= 2048 &&
        data.timestamp is number
      );
    }

    // 3. Collection Specific Rules

    // Users (Sovereign Profile Cards)
    match /users/{userId} {
      allow read, write: if isSignedIn() && (userId == request.auth.uid || isAdmin());
    }

    // Leaderboard entries (Public access read, restricted creator write)
    match /leaderboard/{playerId} {
      allow read: if true;
      allow create, update: if (
        isAdmin() || (
          isSignedIn() &&
          hasPlayerName(playerId) &&
          isValidId(playerId) &&
          isValidLeaderboardEntry(request.resource.data)
        )
      );
      allow delete: if isAdmin() || (isSignedIn() && hasPlayerName(playerId));
    }

    // Announcements (Public read-only, Admin managed)
    match /announcements/{announcementId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Admin Quests (Public read-only, Admin managed)
    match /admin_quests/{questId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Admin Gates (Public read-only, Admin managed)
    match /admin_gates/{gateId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Admin Market Items (Public read-only, Admin managed)
    match /admin_market_items/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Chat Messages
    match /messages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        hasPlayerName(request.resource.data.senderId) &&
        isValidChatMessage(request.resource.data)
      );
      allow delete: if isAdmin();
    }

    // Friendships (Fully mapped relational authorization)
    match /friendships/{friendshipId} {
      allow read: if isSignedIn() && (
        hasPlayerName(resource.data.userUids[0]) ||
        hasPlayerName(resource.data.userUids[1])
      );
      allow create: if isSignedIn() && (
        hasPlayerName(request.resource.data.requestedBy) &&
        (hasPlayerName(request.resource.data.userUids[0]) || hasPlayerName(request.resource.data.userUids[1])) &&
        isValidFriendship(request.resource.data)
      );
      allow update: if isSignedIn() && (
        (hasPlayerName(resource.data.userUids[0]) || hasPlayerName(resource.data.userUids[1])) &&
        isValidFriendship(request.resource.data) &&
        request.resource.data.status == 'accepted' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
      );
      allow delete: if isSignedIn() && (
        hasPlayerName(resource.data.userUids[0]) ||
        hasPlayerName(resource.data.userUids[1])
      );
    }

    // Party Lobbies
    match /party_lobbies/{lobbyId} {
      allow read, write: if isSignedIn();
    }

    // Hunter Forum Posts
    match /hunter_forum/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(postId) && isValidForumPost(request.resource.data);
      allow update, delete: if false; // Posts are immutable
    }

    // Dry-run connection validation
    match /test/{docId} {
      allow read: if true;
    }
  }
}
