{
  "entities": {
    "LeaderboardEntry": {
      "title": "Leaderboard Entry",
      "description": "Represents a user's stats on the global leaderboard, synced with client state",
      "type": "object",
      "properties": {
        "playerName": {
          "type": "string",
          "description": "The name of the player"
        },
        "level": {
          "type": "integer",
          "description": "The current level of the player"
        },
        "gold": {
          "type": "integer",
          "description": "The current gold (Mana) of the player"
        },
        "job": {
          "type": "string",
          "description": "The current job of the player"
        },
        "rank": {
          "type": "string",
          "description": "The current rank of the player"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "The last time the player's stats were serialized"
        }
      },
      "required": ["playerName", "level", "gold", "job", "rank", "updatedAt"]
    },
    "Announcement": {
      "title": "System Announcement",
      "description": "Admin broadcast announcement displayed to all users live",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "severity": { "type": "string", "enum": ["info", "warning", "emergency"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "message", "severity", "createdAt"]
    },
    "AdminQuest": {
      "title": "Admin Crisis Quest",
      "description": "Custom administrative quests published directly from the admin panel",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "target": { "type": "integer" },
        "rewardExp": { "type": "integer" },
        "rewardGold": { "type": "integer" },
        "type": { "type": "string", "enum": ["Daily", "Emergency", "Story"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "description", "target", "rewardExp", "rewardGold", "type", "createdAt"]
    },
    "AdminGate": {
      "title": "Custom Dimensional Gate",
      "description": "Overlord custom dungeons injected into players' systems",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "minLevel": { "type": "integer" },
        "difficulty": { "type": "string" },
        "expReward": { "type": "integer" },
        "goldReward": { "type": "integer" },
        "lootItemName": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "minLevel", "difficulty", "expReward", "goldReward", "lootItemName", "isActive", "createdAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message sent in the global or private chat",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "channel": { "type": "string", "description": "Level or specific chat group" }
      },
      "required": ["senderId", "senderName", "text", "timestamp", "channel"]
    },
    "Friendship": {
      "title": "Friendship Record",
      "description": "Connection between two players",
      "type": "object",
      "properties": {
        "userUids": { "type": "array" },
        "status": { "type": "string", "enum": ["pending", "accepted"] },
        "requestedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userUids", "status", "requestedBy", "createdAt"]
    },
    "PartyLobby": {
      "title": "Party Mode Lobby",
      "description": "Multiplayer session for casual fun",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "hostName": { "type": "string" },
        "mode": { "type": "string" },
        "playerCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "hostName", "mode", "playerCount", "createdAt"]
    }
  },
  "firestore": {
    "/leaderboard/{playerId}": {
      "schema": "LeaderboardEntry",
      "description": "Firestore collection containing all players and their current stats"
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Global admin alerts broadcasted in real-time"
    },
    "/admin_quests/{questId}": {
      "schema": "AdminQuest",
      "description": "Administrative system emergency quests"
    },
    "/admin_gates/{gateId}": {
      "schema": "AdminGate",
      "description": "Custom dungeons injected by global system overrides"
    },
    "/messages/{msgId}": {
      "schema": "ChatMessage",
      "description": "Global and private messages"
    },
    "/friendships/{friendshipId}": {
      "schema": "Friendship",
      "description": "Player relationship records"
    },
    "/party_lobbies/{lobbyId}": {
      "schema": "PartyLobby",
      "description": "Active multiplayer party sessions"
    }
  }
}
